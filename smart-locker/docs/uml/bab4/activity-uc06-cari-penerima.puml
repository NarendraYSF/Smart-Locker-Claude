@startuml activity-uc06-cari-penerima
title Activity Diagram UC-06 — Cari Penerima

skinparam shadowing false
skinparam ActivityBackgroundColor #F4F1E8
skinparam ActivityBorderColor #2A403C
skinparam ActivityDiamondBackgroundColor #FFF7E0
skinparam ActivityDiamondBorderColor #8A6A1F

|#E8F0EE|Kurir|
|#FFF7E0|Sistem Kiosk|

|Kurir|
start
:Tap "Kirim Surat atau Paket"
di layar Idle;

|Sistem Kiosk|
:Render layar **Courier — Search**
(Langkah 1/3);

repeat
  |Kurir|
  :Ketik nama / departemen / NIP
  dari label paket;

  |Sistem Kiosk|
  :Pencarian fuzzy:
  gelar & sapaan diabaikan,
  urutan kata bebas,
  toleransi 1 salah ketik;
  if (Ada hasil?) then (ya)
    :Tampilkan daftar hasil
    + jumlah ("Menampilkan X dari Y");
  else (tidak)
    :Tampilkan "0 hasil" + saran
    "coba nama tanpa gelar";
  endif
repeat while (Penerima ditemukan?) is (belum) not (sudah)

|Kurir|
:Pilih penerima dari daftar;

|Sistem Kiosk|
:Simpan recipient di state;
:Lanjut ke **Pilih Ukuran Paket**
(UC-07);

stop

@enduml
