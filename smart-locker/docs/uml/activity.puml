@startuml activity-loker-pintar-fst
title Activity Diagram — Loker Pintar FST (3 Alur Utama)

skinparam shadowing false
skinparam ActivityBackgroundColor #F4F1E8
skinparam ActivityBorderColor #2A403C
skinparam ActivityDiamondBackgroundColor #FFF7E0
skinparam ActivityDiamondBorderColor #8A6A1F
skinparam PartitionBorderColor #2A403C
skinparam PartitionFontColor #2A403C

|#E8F0EE|Pengguna|
|#FFF7E0|Sistem Kiosk|
|#EAEAEA|Hardware Loker|

|Pengguna|
start
:Mendekati kiosk;

|Sistem Kiosk|
:Tampilkan layar **Idle**
(2 CTA: Staf / Kurir);

|Pengguna|
if (Pilih jalur?) then (**Staf Akademik**)

  :Tap kartu RFID;

  |Sistem Kiosk|
  :Baca UID kartu
  (auto-tap 3.5s hanya mode ?demo);
  if (Kartu valid?) then (ya)
    :Muat data Staf
    (nama, NIP, role, lockerId);
    :Render **Dashboard**
    (loker, kiriman, status);
  else (tidak)
    :Tampilkan toast error;
    stop
  endif

  |Pengguna|
  if (Aksi di dashboard?) then (**Buka Loker Saya**)

    |Sistem Kiosk|
    :Render **Opening Locker**
    reason = "self"
    accent = hijau;
    :Mulai countdown 30 detik;

    |Hardware Loker|
    :Aktifkan solenoid
    (pintu terbuka);

    |Pengguna|
    if (Selesai atau batal?) then (**Selesai**)
      :Ambil/letakkan barang;
      :Tutup pintu;

      |Hardware Loker|
      :Sensor mendeteksi
      pintu tertutup;

      |Sistem Kiosk|
      :Hentikan countdown;
      :Render **Done** "Selesai";
    else (**Batal**)
      |Sistem Kiosk|
      :cancel() → kembali ke
      **Dashboard** tanpa layar sukses;
      stop
    endif

  else (**Surat & Paket**)

    |Sistem Kiosk|
    :Render daftar **Mail**
    (sender, type, locker, waktu);

    |Pengguna|
    :Pilih kiriman → tap **Ambil**;

    |Sistem Kiosk|
    :Render **Opening Locker**
    reason = "claim-mail"
    accent = emas;

    |Hardware Loker|
    :Buka loker target;

    |Pengguna|
    if (Selesai atau batal?) then (**Sudah Diambil**)
      :Ambil kiriman, tutup pintu;

      |Sistem Kiosk|
      :claimMail(id) —
      hapus mail dari daftar;
      if (Loker non-permanen
      dan kosong?) then (ya)
        :locker.state = AVAILABLE;
      else (tidak, loker permanen)
        :Tetap OCCUPIED;
      endif
      :Render **Done**;
    else (**Batal**)
      |Sistem Kiosk|
      :cancel() → kembali ke
      daftar **Mail**;
      stop
    endif

  endif

else (**Tamu / Kurir**)

  |Sistem Kiosk|
  :Render **Courier — Search**
  (Langkah 1/3);

  |Pengguna|
  :Cari penerima
  (nama / dept / NIP,
  fuzzy: gelar diabaikan,
  toleransi 1 typo);
  :Pilih penerima;

  |Sistem Kiosk|
  :Render **Courier — Size**
  (Langkah 2/3);

  |Pengguna|
  :Pilih ukuran paket
  (Surat / Kecil / Sedang / Besar);

  |Sistem Kiosk|
  if (Loker tersedia
  untuk ukuran ini?) then (ya)
    :findFreeLocker(bucket);
    :reserveLocker(id)
    AVAILABLE → DELIVERING;
    :Render **Courier — Assign**
    (peta loker + ringkasan);
  else (tidak)
    :Disable tile ukuran tsb;
    stop
  endif

  |Pengguna|
  if (Lanjut titipkan?) then (**Buka Loker & Titipkan**)

    |Sistem Kiosk|
    :Render **Opening Locker**
    reason = "deliver"
    accent = emas;

    |Hardware Loker|
    :Buka loker target;

    |Pengguna|
    if (Selesai atau batal?) then (**Sudah Diletakkan**)
      :Letakkan paket, tutup pintu;

      |Sistem Kiosk|
      :occupyLocker(id, recipient.nip)
      DELIVERING → OCCUPIED;
      :recordDelivery() —
      paket jadi Mail yang
      bisa diklaim penerima;
      :Kirim notifikasi ke penerima
      **(planned — belum ada)**;
      :Render **Done** +
      **Kode Bukti Titip** "FST-XXXXX"
      (tahan 15 detik untuk difoto);
    else (**Batal**)
      |Sistem Kiosk|
      :cancel() → releaseLocker(id)
      DELIVERING → AVAILABLE;
      :Kembali ke **Courier — Size**;
      stop
    endif

  else (**Ganti Ukuran**)
    |Sistem Kiosk|
    :releaseLocker(id)
    DELIVERING → AVAILABLE;
    :Kembali ke **Courier — Size**;
    stop
  endif

endif

|Sistem Kiosk|
:Tampilkan konfirmasi
(5 detik; deliver: 15 detik);
:Reset state transient
(user, recipient, package, locker);
:Kembali ke **Idle**;

stop

' --- Inactivity branch (cross-cutting) ---
note right
  Cross-cutting (semua layar non-idle):
  * 50 detik tanpa interaksi → overlay
    "Masih di sana?" hitung mundur 10 detik;
    sentuhan apa pun melanjutkan sesi.
  * 60 detik → releaseLocker(loker DELIVERING
    yang terbengkalai), hapus state transient,
    kembali ke **Idle**.
  * Override timeout via ?idle=detik.
  Tombol "Butuh bantuan?" di footer selalu
  tersedia (lokasi, jam layanan, telepon).
end note

@enduml
