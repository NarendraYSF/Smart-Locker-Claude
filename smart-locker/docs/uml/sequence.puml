@startuml sequence-loker-pintar-fst
title Sequence Diagram — Loker Pintar FST (3 Skenario + Inactivity)

skinparam shadowing false
skinparam sequence {
  ArrowColor #2A403C
  ActorBorderColor #2A403C
  LifeLineBackgroundColor #F4F1E8
  LifeLineBorderColor #2A403C
  ParticipantBorderColor #2A403C
  ParticipantBackgroundColor #D9CFA9
  ParticipantFontColor #1B2A26
  GroupBorderColor #8A6A1F
  GroupBackgroundColor #FFF7E0
}

actor "Staf / Kurir" as User
participant "KioskApp\n(state + router)" as App
participant "Screen\n(mounted)" as Screen
participant "DataRepository" as Repo
participant "InactivityTimer" as Timer
participant "RFID Reader" as RFID
participant "Locker Hardware" as HW
participant "Notification\nService <<planned>>" as Notif

== Boot ==
User -> App : open kiosk URL
activate App
App -> App : boot()
App -> App : fitKiosk()  // skala 1080x1920 ke viewport
App -> App : startClock()
App -> App : navigate("idle")
App -> Screen : mountIdle(stage, state)
deactivate App

== Skenario 1 — Staf membuka loker pribadi ==
User  -> Screen : tap "Staf Akademik"
Screen -> App   : navigate("tap-card")
App   -> Screen : mountTapCard(stage, state)

User  -> RFID   : tempel kartu
RFID  -> Screen : onTap(uid)
note right of Screen
  Simulasi: Enter / tombol "Simulasikan Tap".
  Auto-tap 3.5s HANYA pada mode ?demo.
end note
Screen -> Repo  : staff.find(by rfid)
Repo  --> Screen : Staff{nip, name, role, lockerId}
Screen -> App   : navigate("dashboard", {user})
App   -> Timer  : reset()
App   -> Screen : mountDashboard(stage, state)
Screen -> Repo  : mailFor(user.nip)
Repo  --> Screen : Mail[]
Screen -> Repo  : lockers.find(user.lockerId)
Repo  --> Screen : Locker

User  -> Screen : tap "Buka Loker Saya"
Screen -> App   : navigate("opening-locker", {openReason: "self"})
App   -> Screen : mountOpeningLocker(stage, state)
Screen -> HW    : unlock(locker.id)
HW    --> Screen : ack
Screen -> Screen : startCountdown(30s)

alt Selesai — tap "Selesai" / pintu tertutup / countdown habis
  User   -> Screen : tap "Selesai"
  Screen -> HW    : autoLock(locker.id)
  Screen -> App   : navigate("done-screen")
  App    -> Screen : mountDone(stage, state)
  Screen -> Screen : auto-back ke idle (5s)
  Screen -> App   : navigate("idle")
else Batal — cancel()
  User   -> Screen : tap "Batal"
  Screen -> HW    : autoLock(locker.id)
  Screen -> App   : navigate("dashboard")
  note right of Screen
    Kembali ke layar asal,
    TANPA layar sukses.
  end note
end

== Skenario 2 — Staf mengambil kiriman masuk ==
User  -> Screen : (di Dashboard) tap "Surat & Paket"
Screen -> App   : navigate("mail")
App   -> Screen : mountMail(stage, state)
Screen -> Repo  : mailFor(user.nip)
Repo  --> Screen : Mail[]

User  -> Screen : tap "Ambil" pada Mail{id: M-001}
Screen -> App   : navigate("opening-locker", {openReason: "claim-mail", claimedMailId})
App   -> Screen : mountOpeningLocker(stage, state)
Screen -> Repo  : incomingMail.find(M-001)
Repo  --> Screen : Mail
Screen -> Repo  : lockers.find(mail.lockerId)
Repo  --> Screen : Locker
Screen -> HW    : unlock(locker.id)
HW    --> Screen : ack

alt Sudah Diambil — finish()
  User   -> Screen : ambil kiriman, tap "Sudah Diambil"
  Screen -> Repo  : claimMail(M-001)
  note right of Repo
    Hapus mail dari incomingMail.
    Loker kurir (non-permanen) yang
    kosong kembali AVAILABLE; loker
    permanen staf tetap OCCUPIED.
  end note
  Screen -> HW    : autoLock(locker.id)
  Screen -> App   : navigate("done-screen")
else Batal — cancel()
  User   -> Screen : tap "Batal"
  Screen -> HW    : autoLock(locker.id)
  Screen -> App   : navigate("mail")
end

== Skenario 3 — Kurir menitipkan paket ==
User  -> Screen : (di Idle) tap "Kirim Surat atau Paket"
Screen -> App   : navigate("courier-search")
App   -> Screen : mountCourierSearch(stage, state)

loop pencarian iteratif
  User  -> Screen : ketik query
  Screen -> Repo  : searchStaff(q)
  note right of Repo
    Fuzzy: gelar/degree dihapus,
    token bebas urutan, toleransi
    1 typo (token >= 4 huruf).
  end note
  Repo  --> Screen : Staff[] (+ jumlah hasil, "Tampilkan lebih banyak")
end
User  -> Screen : pilih penerima
Screen -> App   : navigate("courier-size", {recipient})
App   -> Screen : mountCourierSize(stage, state)

loop tiap ukuran paket
  Screen -> Repo : countFree(bucket)
  Repo  --> Screen : n
end

User  -> Screen : pilih ukuran (mis. "Paket Sedang")
Screen -> Repo  : findFreeLocker("sedang")
alt Loker tersedia
  Repo  --> Screen : Locker
  Screen -> App   : navigate("courier-assign", {packageSize, assignedLocker})
  App   -> Screen : mountCourierAssign(stage, state)
  Screen -> Repo  : reserveLocker(locker.id)
  note right of Repo : AVAILABLE -> DELIVERING
else Tidak ada
  Repo  --> Screen : null
  Screen -> Screen : disable tile ukuran
end

alt Lanjut — tap "Buka Loker & Titipkan"
  User  -> Screen : tap "Buka Loker & Titipkan"
  Screen -> App   : navigate("opening-locker", {openReason: "deliver"})
  App   -> Screen : mountOpeningLocker(stage, state)
  Screen -> HW    : unlock(assignedLocker.id)
  HW    --> Screen : ack

  alt Sudah Diletakkan — finish()
    User   -> Screen : letakkan paket, tap "Sudah Diletakkan"
    Screen -> Repo  : occupyLocker(id, recipient.nip)
    note right of Repo : DELIVERING -> OCCUPIED
    Screen -> Repo  : recordDelivery({lockerId, recipientNip, type})
    note right of Repo
      Paket terdaftar sebagai Mail
      yang bisa diklaim penerima.
    end note
    Screen -> HW    : autoLock(assignedLocker.id)
    Screen -> Notif : notify(recipient, mail)  <<planned>>
    note right of Notif
      BELUM diimplementasikan —
      backlog: kanal WA/SMS/email.
    end note
    Screen -> App   : navigate("done-screen")
    App    -> Screen : mountDone(stage, state)
    Screen -> Screen : tampilkan Kode Bukti Titip "FST-XXXXX"
    Screen -> Screen : auto-back ke idle (15s, bisa difoto kurir)
  else Batal — cancel()
    User   -> Screen : tap "Batal"
    Screen -> Repo  : releaseLocker(assignedLocker.id)
    note right of Repo : DELIVERING -> AVAILABLE
    Screen -> HW    : autoLock(assignedLocker.id)
    Screen -> App   : navigate("courier-size")
  end
else Kembali — tap "Ganti Ukuran"
  User  -> Screen : tap "Ganti Ukuran"
  Screen -> Repo  : releaseLocker(assignedLocker.id)
  Screen -> App   : navigate("courier-size")
end

== Cross-cutting — Inactivity (semua layar non-idle) ==
User  -> Timer : (tidak ada input 50s)
Timer -> App   : onWarning()
App   -> App   : tampilkan overlay "Masih di sana?"\n(hitung mundur 10 detik)
alt Pengguna menyentuh layar
  User -> App : pointerdown / keydown / touchstart
  App  -> Timer : reset()
  App  -> App   : sembunyikan overlay, sesi lanjut
else Tidak ada respons (total 60s)
  Timer -> App : onTimeout()
  App   -> Repo : releaseLocker(state.assignedLocker?)
  note right of Repo : loker DELIVERING yang\nterbengkalai dibebaskan
  App   -> App  : hapus state transient
  App   -> Screen : mountIdle(stage, state)
end
note over Timer
  Timeout default 60s;
  override via ?idle=detik
  (untuk pengujian).
end note

@enduml
